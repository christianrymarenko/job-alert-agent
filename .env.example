JOB_AGENT_ENV=development
JOB_AGENT_CONFIG_PATH=config.example.yaml
JOB_AGENT_DB_PATH=./data/job_agent.db
JOB_AGENT_LOG_LEVEL=INFO

# SMTP settings
JOB_AGENT_SMTP_HOST=smtp.example.com
JOB_AGENT_SMTP_PORT=587
JOB_AGENT_SMTP_USE_TLS=true
JOB_AGENT_SMTP_USERNAME=your_username
JOB_AGENT_SMTP_PASSWORD=your_password
JOB_AGENT_EMAIL_FROM=job-agent@example.com
JOB_AGENT_EMAIL_TO=recipient@example.com

# Optional: send operational notifications about source failures
JOB_AGENT_NOTIFY_ERRORS=false
